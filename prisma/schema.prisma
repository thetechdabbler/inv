// Prisma schema - Investment Tracker
// ADR-001: All monetary amounts in paise (integer)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// SQLite does not support native enums; use String, validate in app (ADR-001, domain types).
model Account {
  id                   String        @id @default(cuid())
  type                 String        // one of: bank_deposit, stocks, mutual_fund, ppf, epf, nps, gratuity
  name                 String
  description          String?
  initialBalancePaise  Int           @map("initial_balance_paise")
  expectedRatePercent  Float?        @map("expected_rate_percent") // expected annual return (%)
  expectedMonthlyInvest Int?         @map("expected_monthly_invest") // expected monthly investment (paise)
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  transactions         Transaction[]
  valuations           Valuation[]
  marketConfig         AccountMarketConfig?
  employmentInfo       EmploymentInfo?

  @@index([type])
  @@map("accounts")
}

model Transaction {
  id           String          @id @default(cuid())
  accountId    String          @map("account_id")
  date         DateTime
  amountPaise  Int             @map("amount_paise")
  type         String          // investment | withdrawal
  description  String?
  createdAt    DateTime        @default(now())
  account      Account         @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId, date])
  @@map("transactions")
}

model Valuation {
  id          String   @id @default(cuid())
  accountId   String   @map("account_id")
  date        DateTime
  valuePaise  Int      @map("value_paise")
  createdAt   DateTime @default(now())
  account     Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId, date])
  @@map("valuations")
}

// Employment setup info per account (for gratuity and future employment fields)
model EmploymentInfo {
  id             String   @id @default(cuid())
  accountId      String   @unique @map("account_id")
  employerName   String?  @map("employer_name")
  basicSalaryInr Float?   @map("basic_salary_inr")
  vpfAmountInr   Float?   @map("vpf_amount_inr")
  joiningDate    DateTime? @map("joining_date")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  account        Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@map("employment_info")
}

// Bolt 003: PPF/EPF rate per financial year; deposit rate/frequency per account
model InterestRateConfig {
  id                    String   @id @default(cuid())
  accountType           String   @map("account_type") // ppf | epf | bank_deposit
  financialYear         Int?     @map("financial_year") // FY start year (e.g. 2024 = FY 2024-25); null for deposit
  ratePercentPerAnnum   Float    @map("rate_percent_per_annum")
  compoundingFrequency  String?  @map("compounding_frequency") // monthly | quarterly | annual; for deposit only
  accountId             String?  @map("account_id") // for deposit per-account override
  effectiveFrom         DateTime? @map("effective_from")
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@unique([accountType, financialYear, accountId], map: "interest_rate_config_type_year_account_key")
  @@index([accountType])
  @@index([accountId])
  @@map("interest_rate_configs")
}

// Bolt 004: scheme code / ticker and units/shares for MF and stock valuation
model AccountMarketConfig {
  id          String   @id @default(cuid())
  accountId   String   @unique @map("account_id")
  schemeCode  String?  @map("scheme_code")  // MF: mfapi.in scheme code
  ticker      String?  @map("ticker")      // Stock: e.g. RELIANCE.NS
  units       Float?   @map("units")       // MF: number of units
  shares      Float?   @map("shares")     // Stock: number of shares
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  account     Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@map("account_market_configs")
}

// Bolt 007: single-user auth — passphrase hash and PBKDF2 salt (singleton)
model UserConfig {
  id                  String   @id @default(cuid())
  passphraseHash      String   @map("passphrase_hash")
  keyDerivationSalt   String?  @map("key_derivation_salt")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@map("user_config")
}

// Bolt 008: login attempts (purge after 90 days)
model AccessLog {
  id        String   @id @default(cuid())
  action    String   @map("action")
  ipAddress String   @map("ip_address")
  success   Boolean  @map("success")
  timestamp DateTime @default(now()) @map("timestamp")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([timestamp])
  @@map("access_logs")
}

// Bolt 006: LLM interaction audit trail
model LLMQuery {
  id              String       @id @default(cuid())
  insightType     String       @map("insight_type") // summary|projections|risk|rebalancing|query
  prompt          String
  modelRequested  String       @map("model_requested")
  createdAt       DateTime     @default(now()) @map("created_at")
  // Bolt 023: template provenance — nullable for backwards compat
  templateId      String?      @map("template_id")
  templateVersion String?      @map("template_version")
  response        LLMResponse?

  @@index([insightType])
  @@index([createdAt])
  @@map("llm_queries")
}

model LLMResponse {
  id               String    @id @default(cuid())
  queryId          String    @unique @map("query_id")
  responseText     String    @map("response_text")
  modelUsed        String    @map("model_used")
  tokensUsed       Int?      @map("tokens_used")
  success          Boolean
  errorMessage     String?   @map("error_message")
  createdAt        DateTime  @default(now()) @map("created_at")
  // Bolt 023: telemetry — nullable for backwards compat
  promptTokens     Int?      @map("prompt_tokens")
  completionTokens Int?      @map("completion_tokens")
  durationMs       Int?      @map("duration_ms")
  query            LLMQuery  @relation(fields: [queryId], references: [id], onDelete: Cascade)

  @@index([queryId])
  @@map("llm_responses")
}

// Bolt 008: critical data changes (append-only)
model AuditLog {
  id         String   @id @default(cuid())
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id")
  action     String   @map("action")
  oldValue   String?  @map("old_value")
  newValue   String?  @map("new_value")
  timestamp  DateTime @default(now()) @map("timestamp")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([timestamp])
  @@index([entityType])
  @@map("audit_logs")
}
